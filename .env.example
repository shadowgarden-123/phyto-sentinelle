# Copy this file to `.env.local` and fill real values.
# Never commit `.env.local` (it contains secrets).

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI providers (server-only secrets)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# Analytics / Ads (public)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_ADSENSE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:4028
NEXT_PUBLIC_DEMO_MODE=true

# Next.js build toggles (optional)
# IGNORE_BUILD_ERRORS=true
# IGNORE_ESLINT_DURING_BUILDS=true

# Next.js output folder (optional)
# DIST_DIR=.next
